{
  "name": "gluecron",
  "version": "0.1.0",
  "description": "AI-native code intelligence platform — git hosting, automated CI, and green ecosystem enforcement",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gluecron.com/ccantynz/Gluecron.com.git"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "bun test",
    "preflight": "bun scripts/preflight.ts",
    "e2e": "playwright test --config=e2e/playwright.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@neondatabase/serverless": "^1.1.0",
    "@simplewebauthn/server": "^13.3.0",
    "drizzle-orm": "^0.45.2",
    "highlight.js": "^11.11.0",
    "hono": "^4.12.18",
    "marked": "^18.0.3",
    "postgres": "^3.4.9",
    "ssh2": "^1.16.0"
  },
  "optionalDependencies": {
    "cpu-features": "*",
    "sshcrypto": "*"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/bun": "^1.3.14",
    "@types/k6": "^2.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0"
  }
}
