{
  "name": "gluecron-vscode",
  "displayName": "Gluecron",
  "description": "VS Code integration for Gluecron — AI-native code intelligence",
  "version": "0.1.0",
  "publisher": "gluecron",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gluecron.explainFile",
        "title": "Gluecron: Explain This File"
      },
      {
        "command": "gluecron.openOnWeb",
        "title": "Gluecron: Open Current File on Web"
      },
      {
        "command": "gluecron.searchSemantic",
        "title": "Gluecron: Semantic Search"
      },
      {
        "command": "gluecron.generateTests",
        "title": "Gluecron: Generate Tests for Current File"
      }
    ],
    "configuration": {
      "title": "Gluecron",
      "properties": {
        "gluecron.host": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Gluecron server URL"
        },
        "gluecron.token": {
          "type": "string",
          "default": "",
          "description": "Personal access token (glc_...)"
        }
      }
    },
    "menus": {
      "editor/context": [
        { "command": "gluecron.explainFile", "group": "gluecron" },
        { "command": "gluecron.openOnWeb", "group": "gluecron" }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p ."
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
